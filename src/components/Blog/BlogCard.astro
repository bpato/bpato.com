---
export type Prop = {
  excerpt: string;
  title: string;
  slug: string;
  dateGmt: string;
  featuredImage: boolean;
  edges: { tags: string[] };
  variant?: "featured" | "standard" | "compact";
};

const {
  excerpt,
  title,
  slug,
  dateGmt,
  featuredImage: img = false,
  tags: { edges: tags },
  variant = "standard",
} = Astro.props;

const date = new Date(dateGmt).toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});

const titleSize = {
  featured: "text-2xl md:text-4xl",
  standard: "text-lg md:text-2xl",
  compact: "text-base md:text-xl",
}[variant];

const padding = {
  featured: "p-6 md:p-8",
  standard: "p-5",
  compact: "p-4",
}[variant];
---

<article class="blog-card group bg-theme-black z-0 overflow-hidden transition-all duration-300 hover:shadow-[0_0_0_1px_var(--color-primary-light),0_8px_24px_rgba(0,0,0,0.3)]" data-variant={variant}>
  <a class="read-more block" href={`/post/${slug}`} data-astro-history="replace">
    {
      img && (
        <div class="media relative overflow-hidden">
          <img
            class="aspect-video w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
            src={img.node.sourceUrl}
            alt={img.node.altText}
            srcset={img.node.srcSet}
            sizes="(max-width: 768px) 100vw, (max-width: 1280px) 50vw, 33vw"
          />
        </div>
      )
    }
    <div class={`card-body text-theme-grey-medium ${padding}`}>
      <div class="flex flex-col h-full">
        <div class="card-date text-xs font-medium mb-3 text-primary-light">
          <time>{date}</time>
        </div>
        <div class="card-title mb-3 text-white">
          <h3 class={`title ${titleSize} font-semibold transition-colors duration-300 group-hover:text-primary-light`}>{title}</h3>
        </div>
        <div class="divider border-t border-theme-grey-dark my-3"></div>
        <div class="card-excerpt text-white flex-1 mb-3">
          <div
            class="paragraph text-justify leading-normal font-light"
            set:html={excerpt}
          />
        </div>
        {
          tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-auto pt-2">
              {tags.map(({ node }: any) => (
                <span class="tag-badge inline-block bg-primary-light/10 text-primary-light text-xs font-medium px-2.5 py-1 rounded-full transition-colors duration-300 group-hover:bg-primary-light/20">
                  {node.name}
                </span>
              ))}
            </div>
          )
        }
      </div>
    </div>
  </a>
</article>
