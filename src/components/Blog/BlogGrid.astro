---
import BlogCard from "@/components/Blog/BlogCard.astro";
import BlogLine from "@/components/Blog/BlogLine.astro";

export type Post = {
    slug: string;
    title: string;
    excerpt: string;
    dateGmt: string;
    featuredImage?: {
        node: {
            altText: string;
            uri: string;
            srcSet: string;
            sourceUrl: string;
        };
    };
    tags?: {
        edges: { node: { name: string } }[];
    };
};

export type Props = {
    posts: Post[];
};

const { posts } = Astro.props;

const featured = posts[0];
const secondary = posts.slice(1, 3);
const compact = posts.slice(3, 6);
---

<section class="grid grid-flow-col grid-cols-[20px_auto_20px] grid-rows-1 gap-4 bg-theme-grey-dark">
    <div class="bg-theme-black"></div>
    <div class="pt-8 pb-12 px-5 max-w-6xl mx-auto">
        {featured && (
            <div class="blog-grid">
                <BlogCard {...featured} variant="featured" />
            </div>
        )}

        {secondary.length > 0 && (
            <div class="blog-grid-secondary grid grid-cols-1 md:grid-cols-2 gap-4 mt-6">
                {secondary.map((post) => <BlogCard {...post} variant="standard" />)}
            </div>
        )}

        {compact.length > 0 && (
            <div class="blog-grid-compact grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mt-6">
                {compact.map((post) => <BlogCard {...post} variant="compact" />)}
            </div>
        )}
    </div>
    <div class="bg-theme-black"></div>
</section>

<section class="grid grid-flow-col grid-cols-[20px_auto_20px] grid-rows-1 bg-theme-grey-dark">
    <div class="bg-theme-grey-dark"></div>
    <div class="bg-theme-black grid grid-cols-1 md:grid-cols-[20%_80%] grid-rows-[100px_80%] md:grid-rows-1 grid-flow-row md:grid-flow-col p-5 lg:p-30">
        <div class="border-b-1 md:border-r-1 md:border-b-0 border-theme-grey-dark">
            <h2 class="font-special text-4xl mx-5 pt-5 md:pt-0">Feed</h2>
        </div>
        <div class="my-2 flex-wrap flex flex-row">
            {posts.map((post) => <BlogLine {...post} />)}
        </div>
    </div>
    <div class="bg-theme-grey-dark"></div>
</section>

<style>
    :global(.blog-grid) {
        margin-bottom: 4px;
    }

    :global(.blog-grid .blog-card[data-variant="featured"]) {
        margin-bottom: 0;
    }

    :global(.blog-grid-secondary .blog-card) {
        margin-bottom: 0;
    }

    :global(.blog-grid-compact .blog-card .media) {
        display: none;
    }
</style>
