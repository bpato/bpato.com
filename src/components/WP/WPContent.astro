---
export type Props = {
    class?: string;
};

const { class: className = "" } = Astro.props;
---

<div class:list={["wp-content", className]}>
    <slot />
</div>

<style>
    .wp-content :global(h1),
    .wp-content :global(h2),
    .wp-content :global(h3),
    .wp-content :global(h4),
    .wp-content :global(h5),
    .wp-content :global(h6) {
        font-weight: bold;
        margin-block: calc(var(--spacing) * 5);
    }

    .wp-content :global(.wp-block-heading),
    .wp-content :global(h2) {
        font-size: var(--text-2xl);
        line-height: var(--tw-leading, var(--text-2xl--line-height));
    }

    .wp-content :global(h3) {
        font-size: var(--text-xl);
        line-height: var(--tw-leading, var(--text-xl--line-height));
    }

    .wp-content :global(h1) {
        font-size: var(--text-4xl);
        line-height: var(--tw-leading, var(--text-4xl--line-height));
    }

    .wp-content :global(p) {
        margin-block: calc(var(--spacing) * 5);
    }

    .wp-content :global(blockquote) {
        font-style: italic;
        margin-left: 32px;
        border-left: 4px solid var(--color-primary-light);
        padding-left: 8px;
    }

    .wp-content :global(pre.wp-block-code) {
        background-color: #1e1e1e;
        color: #dcdcdc;
        padding: 1em;
        border-radius: 8px;
        overflow-x: auto;
        font-size: 0.95em;
        line-height: 1.5;
        margin-bottom: 1.5em;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
        border: 1px solid #333;
        white-space: pre-wrap;
        word-break: break-word;
    }

    .wp-content :global(pre.wp-block-code > code) {
        font-family: "Fira Code", "Courier New", monospace;
        font-weight: 400;
        color: inherit;
    }

    .wp-content :global(pre.wp-block-code > code > .comment) {
        color: var(--color-primary-light);
        font-style: italic;
    }

    .wp-content :global(code:not(pre code)) {
        background-color: #f5f5f5;
        color: #c7254e;
        padding: 0.2em 0.4em;
        border-radius: 4px;
        font-size: 0.9em;
    }
</style>
